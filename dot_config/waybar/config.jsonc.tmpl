// -*- mode: jsonc -*-
{
  "layer": "top", // Display in front (top) or behind windows (bottom)
  "position": "top", // Position (top, bottom, left, right)
  "height": 25,
  "spacing": 5, // Gaps between modules
  "reload_style_on_change": true,
  "modules-left": [
    "custom/power",
    "clock",
    "power-profiles-daemon",
    "cpu",
    "memory",
    "temperature",
  ],
  "modules-center": ["hyprland/workspaces"],
  "modules-right": [
    "idle_inhibitor",
    "network",
    "custom/vpn",
    "bluetooth",
    "pulseaudio",
    "battery",
  ],
  "custom/power": {
    "format": "´Çæ ",
    "tooltip": false,
    "menu": "on-click",
    "menu-file": "~/.config/waybar/power-menu.xml",
    "menu-actions": {
      "suspend": "systemctl suspend",
      "reboot": "reboot",
      "shutdown": "shutdown now",
      "logout": "hyprctl dispatch exit",
    },
  },
  "clock": {
    "format": "{:%I:%M %p}",
    "format-alt": "{:%m-%d-%Y}",
    "tooltip-format": "<tt><big>{calendar}</big></tt>",
    "calendar": {
      "mode": "month",
      "mode-mon-col": 3,
      "on-scroll": 1,
      "format": {
        "months": "<span color='#cacace'><b>{}</b></span>",
        "days": "<span color='#cacace'>{}</span>",
        "weekdays": "<span color='#cacace'><b>{}</b></span>",
        "today": "<span background='#ff6685' foreground='#0a0a08'><b><u>{}</u></b></span>",
      },
    },
    "actions": {
      "on-click-right": "mode",
      "on-click-middle": "shift_reset",
      "on-scroll-up": "shift_down",
      "on-scroll-down": "shift_up",
    },
  },
  "power-profiles-daemon": {
    "format": "{icon}",
    "tooltip-format": "Power profile: {profile}\nDriver: {driver}",
    "tooltip": true,
    "format-icons": {
      "default": "´âº",
      "performance": "´âº",
      "balanced": "´ëÄ ",
      "power-saver": "´ü¼ ",
    },
  },
  "cpu": {
    "format": "´Æ╝   {usage}%",
  },
  "memory": {
    "format": "¯┐à   {percentage}%   ¾░»ì  {swapPercentage}%",
    "tooltip-format": "Memory: {used:0.2f} GiB used\nSwap: {swapUsed:0.2f} GiB used",
  },
  "temperature": {
    "format": "´ïë  {temperatureC}┬░C",
    {{- if eq .chezmoi.hostname "gored" }}
    "hwmon-path-abs": "/sys/devices/pci0000:00/0000:00:18.3/hwmon",
    "input-filename": "temp1_input",
    {{- else if eq .chezmoi.hostname "gorel" }}
    "hwmon-path-abs": "/sys/devices/platform/coretemp.0/hwmon",
    "input-filename": "temp1_input",
    {{- end }}
    "tooltip-format": "{temperatureF}┬░F\n{temperatureK} K",
  },
  "hyprland/workspaces": {
    "show-special": true,
    "all-outputs": true,
    "on-scroll-up": "hyprctl dispatch workspace e-1",
    "on-scroll-down": "hyprctl dispatch workspace e+1",
  },
  "idle_inhibitor": {
    "format": "{icon}",
    "format-icons": {
      "activated": "¾░îÁ",
      "deactivated": "¾░╣Å",
    },
  },
  "network": {
    "format-wifi": "{icon}  {essid}",
    "format-icons": {
      "default": ["¾░ñ» ", "¾░ñƒ ", "¾░ñó ", "¾░ñÑ ", "¾░ñ¿ "],
    },
    "format-ethernet": "¯¢ä   {ifname}",
    "format-disconnected": "´ü▒   Disconnected",
    "tooltip-format": "{gwaddr}/{cidr}",
    "tooltip-format-wifi": "{essid} ({signalStrength}%) ({gwaddr}/{cidr})",
    "max-length": 15,
  },
  "custom/vpn": {
    "format": "{}",
    "exec": "~/.config/waybar/scripts/vpn.sh",
    "return-type": "json",
    "interval": 5,
    "max-length": 15,
  },
  "bluetooth": {
    "format": "¾░é» {num_connections}",
    "format-disabled": "¾░é▓",
    "format-off": "¾░é▓",
    "format-no-controller": "¾░é▓",
    "on-click": "bluetoothctl power $(bluetoothctl show | rg -q 'Powered: yes' && echo off || echo on)",
    "tooltip": true,
    "tooltip-format": "{device_enumerate}",
    "tooltip-format-enumerate-connected": "{device_alias}  ¾░Ñë {device_battery_percentage}%",
  },
  "pulseaudio": {
    "scroll-step": 5,
    "format": "{icon}   {volume}%   {format_source}",
    "format-bluetooth": "¾░é» {icon}   {volume}%   {format_source}",
    "format-bluetooth-muted": "¾░é» ¯╗¿   {volume}%   {format_source}",
    "format-muted": "¯╗¿   {volume}%   {format_source}",
    "format-source": "´ä░ {volume}%",
    "format-source-muted": "´ä▒  {volume}%",
    "format-icons": {
      "default": ["´Çª", "´Çº", "´Ç¿ "],
    },
    "on-click": "pactl set-sink-mute @DEFAULT_SINK@ toggle",
    "on-click-right": "pactl set-source-mute @DEFAULT_SOURCE@ toggle",
  },
  "battery": {
    "format": "{icon}  {capacity}%",
    "format-full": "{icon}  {capacity}%",
    "format-charging": "¾░éä  {capacity}% ",
    "format-plugged": "´çª  {capacity}%",
    "format-alt": "{icon}  {time}",
    "format-icons": ["´ëä ", "´ëâ ", "´ëé ", "´ëü ", "´ëÇ "],
  },
}
